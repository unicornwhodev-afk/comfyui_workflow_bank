{
  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input_video.mp4",
      "force_rate": 24,
      "force_size": "Disabled",
      "custom_width": 512,
      "custom_height": 512,
      "frame_load_cap": 48,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "2": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "realisticVisionV51_v51VAE.safetensors"
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["1", 0],
      "vae": ["2", 2]
    }
  },
  "4": {
    "class_type": "ADE_AnimateDiffLoaderWithContext",
    "inputs": {
      "model": ["2", 0],
      "model_name": "v3_sd15_mm.ckpt",
      "beta_schedule": "sqrt_linear (AnimateDiff)",
      "motion_scale": 1.0,
      "apply_v2_models_properly": false
    }
  },
  "5": {
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ip-adapter-plus_sd15.safetensors"
    }
  },
  "6": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "7": {
    "class_type": "IPAdapterApply",
    "inputs": {
      "model": ["4", 0],
      "ipadapter": ["5", 0],
      "image": ["1", 0],
      "clip_vision": ["6", 0],
      "weight": 0.85,
      "start_at": 0.0,
      "end_at": 1.0,
      "weight_type": "linear"
    }
  },
  "8": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 1],
      "text": "pixel art character animation, game sprite, smooth animation loop, seamless loop, consistent character, same pose start and end, perfect loop, high quality"
    }
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 1],
      "text": "blurry, bad quality, distorted, different character, morphing, changing appearance, inconsistent, noise, artifacts"
    }
  },
  "10": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["7", 0],
      "positive": ["8", 0],
      "negative": ["9", 0],
      "latent_image": ["3", 0],
      "seed": 42,
      "control_after_generate": "fixed",
      "steps": 20,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 0.35
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["2", 2]
    }
  },
  "12": {
    "class_type": "ImageBatch",
    "inputs": {
      "images": ["11", 0]
    }
  },
  "13": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["11", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "looped_animation",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  },
  "14": {
    "class_type": "VHS_SplitImages",
    "inputs": {
      "images": ["11", 0]
    }
  },
  "15": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["11", 0],
      "filename_prefix": "frames/animation"
    }
  }
}
